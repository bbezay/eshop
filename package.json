{
  "name": "shoe-store-be",
  "version": "1.0.0",
  "description": "Shoe Store Backend API built with Express.js and PostgreSQL",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "create-db": "node scripts/create-db.js",
    "migrate": "node scripts/migrate.js up",
    "migrate:rollback": "node scripts/migrate.js down",
    "seed": "node scripts/seed.js",
    "setup": "npm run create-db && npm run migrate && npm run seed"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.13.1",
    "sharp": "^0.34.5"
  }
}
